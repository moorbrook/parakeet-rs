<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>NSMicrophoneUsageDescription</key>
  <string>Parakeet needs microphone access to transcribe your speech to text.</string>
  <key>NSAppleEventsUsageDescription</key>
  <string>Parakeet uses Accessibility to paste transcribed text into the focused window.</string>
  <key>LSUIElement</key>
  <true/>
  <!-- CFBundleIconFile names the .icns inside Contents/Resources/ when
       we eventually ship a .app bundle. The `.icns` extension is omitted
       per Apple's convention. -->
  <key>CFBundleIconFile</key>
  <string>icon</string>
</dict>
</plist>
